# LLM backend: gemini | anthropic | openai
LLM_BACKEND=gemini

# Required for LLM_BACKEND=gemini - free tier at aistudio.google.com
GEMINI_API_KEY=

# Required for LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=

# Required for LLM_BACKEND=openai
OPENAI_API_KEY=

# Required - free at pexels.com/api
PEXELS_API_KEY=

# Optional second stock source - free at pixabay.com/api
PIXABAY_API_KEY=

# Optional - for --telegram delivery flag
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
